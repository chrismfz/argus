/var/log/argus/*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 root root
    sharedscripts
    postrotate
        # Tell systemd to reopen the log files after rotation
        systemctl kill -s SIGUSR1 argus.service >/dev/null 2>&1 || true
    endscript
}
